<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formularios ou Forms</title>
</head>
<body>
    <h1>Formularios</h1>
    <form>
        <label>Nome:</label>
        <input type="text" placeholder="Seu nome" /> <br/>
        <label for="email"> E-mail:</label>
        <input id="email" type="email" placeholder="Seu e-mail"/> <br/>
        <label>Telefone:</label>
        <input type="tel" placeholder="Seu telefone"/><br/>
        <label>Numeros:</label>
        <input type="number" placeholder="67?" max="67" min="-67" step="67"/><br/>
        <label>Arquivos:</label><br/>
        <input type="file"/><br/>
        <input type="color" /><br/>
        <input type="checkbox" id="checkbox-termos"/> <label for="checkbox-termos"> Aceito os termos</label><br/>
        <p>
            Qual sua cor favorita?
        </p>
        <input type="radio" name="cor-favorita" id="cor-vermelha"/><label for="cor-vermelha">Vermelho</label>
        <input type="radio" name="cor-favorita" id="cor-verde"/><label for="cor-verde">Verde</label>
        <input type="radio" name="cor-favorita" id="cor-azul"/><label for="cor-azul">Azul</label>
        <p></p>
        <label>Qual desses é seu filme favorito:</label> 
            <select>
            <option>Nenhum</option>
            <option>Diario de uma paixão</option>
            <option>Click</option>
            <option>Todo mundo em panico</option>
            </select>
            <br/><br/>
            <textarea placeholder="Caso não esteja coloque aqui seu filme favorito"></textarea>
            <br/><br/>
            <button type="submit">
             Enviar
            </button>
            <button type="reset">
            Limpar
            </button>
    </form>
</body>
</html>
